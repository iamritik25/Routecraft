# RouteCraft — Environment Configuration (Template)
# Copy this file to .env and fill in your local settings.
# This file is committed to Git. The actual .env is NOT.

# ── Flask ──────────────────────────────────────────────────────────────────
# A secure, random string for signing session cookies. 
# You can generate one with: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=replace-this-with-a-real-random-key
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# ── ML Backend ─────────────────────────────────────────────────────────────
# Options: lightgbm | mps_nn | sklearn
# 'sklearn' is the safe default — it works on almost any machine.
TRAFFIC_MODEL_TYPE=sklearn

# ── A/B Testing ────────────────────────────────────────────────────────────
# Percentage of traffic (0-100) sent to the experimental backend (mps_nn).
MPS_TRAFFIC_PERCENT=10

# ── Redis Graph Cache (optional) ───────────────────────────────────────────
# Leave blank to use the built-in in-process dictionary cache (recommended for dev).
# Format: redis://localhost:6379/0
REDIS_URL=

# ── Geocoder ───────────────────────────────────────────────────────────────
# RouteCraft uses Nominatim (OSM). No API key is needed.
# Please change this user-agent to something unique (e.g. routecraft-yourname-2026)
# so the OpenStreetMap team can reach you if there's an issue.
GEOCODER_USER_AGENT=routecraft-dev-user

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=200 per hour
RATE_LIMIT_ROUTE=60 per minute

# ── Open-Meteo Weather API ────────────────────────────────────────────────
# Used by cache_warmer.py to fetch live Bangalore weather.
# This API is completely free and requires no key or account.
OPEN_METEO_LAT=12.9716
OPEN_METEO_LON=77.5946
